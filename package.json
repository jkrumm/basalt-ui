{
  "name": "basalt-ui-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "dev:playground": "bun --filter @basalt-ui/playground dev",
    "dev:marketing": "bun --filter marketing dev",
    "dev": "bun --filter @basalt-ui/playground dev",
    "dev:plugin": "claude --plugin-dir ./plugins/basalt",
    "fmt": "oxfmt --ignore-path=.gitignore --ignore-path=.oxfmtignore packages apps/playground *.json *.md",
    "fmt:check": "oxfmt --check --ignore-path=.gitignore --ignore-path=.oxfmtignore packages apps/playground *.json *.md",
    "format": "bun run fmt",
    "lint": "oxlint",
    "typecheck": "bun --filter basalt-ui --filter @basalt-ui/playground typecheck",
    "test": "bun test",
    "pre": "bun run fmt:check && bun run lint && bun run typecheck",
    "prepare": "lefthook install",
    "hooks:install": "lefthook install",
    "hooks:uninstall": "lefthook uninstall"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@commitlint/types": "^20.4.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2"
  }
}
