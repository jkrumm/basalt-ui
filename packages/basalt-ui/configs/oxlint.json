{
  "plugins": ["react", "typescript", "import", "unicorn", "jsx-a11y", "promise", "oxc"],
  "jsPlugins": ["./oxlint-plugin.js"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-var": "error",
    "eqeqeq": ["error", "smart"],
    "no-console": "warn",
    "no-shadow": "off",
    "react/rules-of-hooks": "error",
    "react/jsx-key": "error",
    "react/react-in-jsx-scope": "off",
    "typescript/no-explicit-any": "warn",
    "import/no-duplicates": "error",
    "import/no-unassigned-import": "off",
    "basalt/no-raw-font-size": "error",
    "basalt/card-inset": "error",
    "basalt/chart-in-raw-surface": "error",
    "basalt/raw-scroll-container": "off",
    "basalt/visx-boundary": "error",
    "basalt/visx-tooltip": "error"
  },
  "overrides": [
    {
      "files": ["**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "antd",
                "message": "Use Mantine — antd is not part of the basalt-ui stack."
              },
              {
                "name": "framer-motion",
                "message": "Import from 'motion/react', not the raw framer-motion package."
              }
            ]
          }
        ]
      }
    }
  ]
}
