{
  "name": "basalt-ui",
  "version": "0.4.2",
  "description": "Opinionated framework for Mantine-based React apps — theme, app shell, visx charts, toolchain presets",
  "keywords": [
    "charts",
    "design-system",
    "mantine",
    "oxlint",
    "react",
    "theme",
    "visx"
  ],
  "homepage": "https://basalt-ui.com?utm_source=npm_package",
  "bugs": {
    "url": "https://github.com/jkrumm/basalt-ui/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Johannes Krumm",
    "url": "https://jkrumm.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jkrumm/basalt-ui.git",
    "directory": "packages/basalt-ui"
  },
  "bin": {
    "basalt": "./bin/basalt.mjs"
  },
  "files": [
    "dist/",
    "src/",
    "configs/",
    "bin/",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "import": "./dist/charts/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./theme-lab": {
      "types": "./dist/theme-lab/index.d.ts",
      "import": "./dist/theme-lab/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./styles.css": "./dist/styles.css",
    "./configs/*": "./configs/*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css && tsc --emitDeclarationOnly --declarationMap && bun scripts/fix-esm-extensions.mjs",
    "typecheck": "tsc --noEmit",
    "pack-test": "bash scripts/pack-test.sh",
    "prepack": "bun run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@visx/axis": "4.0.0-alpha.11",
    "@visx/curve": "4.0.0-alpha.11",
    "@visx/event": "4.0.0-alpha.11",
    "@visx/grid": "4.0.0-alpha.11",
    "@visx/group": "4.0.0-alpha.11",
    "@visx/scale": "4.0.0-alpha.11",
    "@visx/shape": "4.0.0-alpha.11",
    "@visx/threshold": "4.0.0-alpha.11"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "@mantine/core": "^9.3.0",
    "@mantine/dates": "^9.3.0",
    "@mantine/hooks": "^9.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependenciesMeta": {
    "@mantine/dates": {
      "optional": true
    }
  },
  "basalt": {
    "roots": [
      "src"
    ]
  }
}
