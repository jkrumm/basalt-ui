{
  "name": "basalt-ui",
  "version": "0.4.2",
  "description": "Unified Tailwind CSS design system for modern UI libraries",
  "license": "Apache-2.0",
  "type": "module",
  "author": {
    "name": "Johannes Krumm",
    "url": "https://jkrumm.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jkrumm/basalt-ui.git",
    "directory": "packages/basalt-ui"
  },
  "homepage": "https://basalt-ui.com?utm_source=npm_package",
  "bugs": {
    "url": "https://github.com/jkrumm/basalt-ui/issues"
  },
  "keywords": [
    "tailwindcss",
    "tailwind",
    "css",
    "design-system",
    "theme",
    "oklch",
    "shadcn",
    "react",
    "components",
    "astro",
    "starlight"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./css": {
      "style": "./src/index.css",
      "import": "./src/index.css"
    },
    "./starlight": {
      "style": "./src/starlight.css",
      "import": "./src/starlight.css"
    }
  },
  "files": [
    "src/",
    "dist/",
    "tailwind.config.js",
    "tsconfig.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@base-ui/react": "^1.0.0",
    "@fontsource-variable/geist": "^5.0.0",
    "@fontsource-variable/jetbrains-mono": "^5.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tabler/icons-react": "^3.0.0",
    "react": "^19.0.0",
    "shadcn": "^3.8.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependenciesMeta": {
    "@base-ui/react": {
      "optional": true
    },
    "@fontsource-variable/geist": {
      "optional": true
    },
    "@fontsource-variable/jetbrains-mono": {
      "optional": true
    },
    "@tabler/icons-react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "sideEffects": [
    "./src/index.css",
    "./src/starlight.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "bun x tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
