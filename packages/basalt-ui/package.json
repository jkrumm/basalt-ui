{
  "name": "basalt-ui",
  "version": "1.1.0",
  "description": "Opinionated framework for Mantine-based React apps — theme, app shell, visx charts, toolchain presets",
  "keywords": [
    "charts",
    "design-system",
    "mantine",
    "oxlint",
    "react",
    "theme",
    "visx"
  ],
  "homepage": "https://github.com/jkrumm/basalt-ui/tree/master/packages/basalt-ui#readme",
  "bugs": {
    "url": "https://github.com/jkrumm/basalt-ui/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Johannes Krumm",
    "url": "https://jkrumm.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkrumm/basalt-ui.git",
    "directory": "packages/basalt-ui"
  },
  "bin": {
    "basalt-ui": "./bin/basalt-ui.mjs"
  },
  "files": [
    "dist/",
    "src/",
    "configs/",
    "agent/",
    "bin/",
    "llms.txt",
    "AGENTS.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "import": "./dist/charts/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./theme-lab": {
      "types": "./dist/theme-lab/index.d.ts",
      "import": "./dist/theme-lab/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./guard": {
      "types": "./dist/guard/index.d.ts",
      "import": "./dist/guard/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "import": "./dist/commands/index.js"
    },
    "./notifications": {
      "types": "./dist/notifications/index.d.ts",
      "import": "./dist/notifications/index.js"
    },
    "./query": {
      "types": "./dist/query/index.d.ts",
      "import": "./dist/query/index.js"
    },
    "./router-tanstack": {
      "types": "./dist/router-tanstack/index.d.ts",
      "import": "./dist/router-tanstack/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js"
    },
    "./data/table": {
      "types": "./dist/data/table.d.ts",
      "import": "./dist/data/table.js"
    },
    "./data/virtual": {
      "types": "./dist/data/virtual.d.ts",
      "import": "./dist/data/virtual.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./state": {
      "types": "./dist/state.d.ts",
      "import": "./dist/state.js"
    },
    "./connectivity": {
      "types": "./dist/connectivity/index.d.ts",
      "import": "./dist/connectivity/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./configs/*": "./configs/*",
    "./llms.txt": "./llms.txt"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationMap && bun scripts/copy-assets.mjs && bun scripts/fix-esm-extensions.mjs",
    "typecheck": "tsc --noEmit",
    "pack-test": "bash scripts/pack-test.sh",
    "prepack": "bun run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fontsource-variable/hubot-sans": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource-variable/nunito-sans": "5.2.7",
    "@visx/axis": "4.0.0",
    "@visx/curve": "4.0.0",
    "@visx/event": "4.0.0",
    "@visx/grid": "4.0.0",
    "@visx/group": "4.0.0",
    "@visx/responsive": "4.0.0",
    "@visx/scale": "4.0.0",
    "@visx/shape": "4.0.0",
    "@visx/threshold": "4.0.0",
    "motion": "12.42.0",
    "remend": "1.3.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@shikijs/langs": "^4.3.1",
    "@shikijs/themes": "^4.3.1",
    "@tanstack/react-hotkeys": "0.10.0",
    "@types/bun": "^1.3.14",
    "@types/hast": "^3.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ai": "^7.0.15",
    "beautiful-mermaid": "^1.1.3",
    "publint": "0.3.21",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "use-stick-to-bottom": "^1.1.6",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  },
  "peerDependencies": {
    "@mantine/core": "^9.3.0",
    "@mantine/form": "^9.3.0",
    "@mantine/hooks": "^9.3.0",
    "@mantine/modals": "^9.3.0",
    "@mantine/notifications": "^9.3.0",
    "@mantine/spotlight": "^9.3.0",
    "@shikijs/langs": "^4.3.1",
    "@shikijs/themes": "^4.3.1",
    "@tanstack/react-hotkeys": "0.10.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router": "^1.170.0",
    "@tanstack/react-table": ">=8 <9",
    "@tanstack/react-virtual": ">=3 <4",
    "ai": "^7.0.15",
    "beautiful-mermaid": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.0",
    "use-stick-to-bottom": "^1.1.6",
    "vite": "^7 || ^8",
    "vite-plugin-pwa": "^1.3.0"
  },
  "peerDependenciesMeta": {
    "@mantine/form": {
      "optional": true
    },
    "@shikijs/langs": {
      "optional": true
    },
    "@shikijs/themes": {
      "optional": true
    },
    "@tanstack/react-hotkeys": {
      "optional": true
    },
    "@mantine/modals": {
      "optional": true
    },
    "@mantine/notifications": {
      "optional": true
    },
    "@mantine/spotlight": {
      "optional": true
    },
    "@tanstack/react-query-devtools": {
      "optional": true
    },
    "@tanstack/react-router": {
      "optional": true
    },
    "@tanstack/react-table": {
      "optional": true
    },
    "@tanstack/react-virtual": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "beautiful-mermaid": {
      "optional": true
    },
    "react-markdown": {
      "optional": true
    },
    "remark-gfm": {
      "optional": true
    },
    "shiki": {
      "optional": true
    },
    "use-stick-to-bottom": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vite-plugin-pwa": {
      "optional": true
    }
  },
  "basalt": {
    "roots": [
      "src"
    ],
    "exempt": [
      "src/tokens/palette.ts",
      "src/tokens/index.ts",
      "src/theme/index.ts",
      "src/guard/index.ts",
      "src/cli/index.ts"
    ],
    "rawSurface": false,
    "rawHtmlLayout": false,
    "inlineSpacing": false,
    "inlineDisplay": false,
    "rawRadius": false,
    "spacingSteps": []
  }
}
